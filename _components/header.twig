<header class="w-full {{ front_page ? 'absolute' : 'bg-primary-darkest' }} z-50 lg:fixed lg:z-20 lg:top-0 lg:left-0 lg:pt-0">

  <p class="p-2 text-sm text-center text-white bg-secondary xl:hidden">Find out how much your home is worth today! 
    {% if hitchin %}
      <span class="inline-block font-bold">
        Hitchin
        <a href="tel:01462690525" class="inline-block font-bold" onclick="gtag('event', 'Phone Call', {'event_category': 'Phone Call', 'event_label': 'Phone call click to call'});">
          01462 690525
        </a>
      </span>
    {% else %}
      <span class="inline-block font-bold">
        {{options.default_location}}
        {% include "_components/phone-number.twig" %}
      </span>
      |
      <span class="inline-block font-bold">
        Hitchin
        <a href="tel:01462690525" class="inline-block font-bold" onclick="gtag('event', 'Phone Call', {'event_category': 'Phone Call', 'event_label': 'Phone call click to call'});">
          01462 690525
        </a>
      </span>
    {% endif %}
  </p>

  <div class="container items-center justify-between header-container lg:flex">

    <div class="flex flex-wrap justify-between">

      <a aria-label="Go to homepage" class="block w-2/3 clear lg:w-auto lg:inline-block" href="{{site.site_url}}">
        <img class="block w-full py-4 lg:py-0 max-w-40 xl:max-w-56" src="{{options.logo_horizontal_white.url}}" alt="{{site.title}} Logo" />
      </a>

      <div class="flex items-center justify-end w-1/3 p-2 text-center text-white menu-btn lg:hidden">
        {{ function('icon', 'bars') }}<span class="ml-1 font-bold">Menu</span></div>
    </div>    

    <div class="items-center justify-end lg:flex">

      <nav id="menu-primary" class="hidden menu lg:block menu-primary {{front_page ? 'front-page' : '' }}">
        <ul class="flex flex-wrap justify-center w-full menu-primary">
          {% for item in primaryMenu.items %}
          <li class="{{item.class}} {{ item.current ? 'current-menu-item' }}">
            <a href="{{item.link}}">{{item.name}}</a>
            {% if item.children %}
            <ul class="sub-menu">
              {% for child in item.children %}
              <li class="{{child.class}}">
                <a href="{{child.link}}">{{child.name}}</a>
              </li>
              {% endfor %}
            </ul>
            {% endif %}
          </li>
          {% endfor %}
        </ul>
      </nav>

      <a href="{{site.url ~ '/contact-us'}}" class='items-center justify-center hidden px-4 py-2 font-bold bg-white rounded-full 2xl:px-4 2xl:py-2 text-primary-dark lg:flex md::ml-2 md:text-sm 2xl:text-base hover:bg-primary-light'>
        Contact us
      </a>
      
    </div>
   
  </div>
  

</header>